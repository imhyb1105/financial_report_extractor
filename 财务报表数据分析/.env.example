# 环境变量配置文件模板
# 复制此文件为 .env 并填写实际值

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ==================== 数据库提供商 ====================
# 选择数据库提供商: 'sqlite' (本地开发) 或 'supabase' (生产环境)
DATABASE_PROVIDER=sqlite

# ==================== Supabase 配置 ====================
# Supabase 项目 URL (从 Supabase Dashboard 获取)
SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥 (从 Supabase Dashboard > Settings > API 获取)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase 服务密钥 (用于服务端操作，从 Supabase Dashboard > Settings > API 获取)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ==================== 安全配置 ====================
# JWT密钥（生产环境必须修改为随机字符串）
JWT_SECRET=your-jwt-secret-change-in-production

# 管理员密码（生产环境必须修改）
ADMIN_PASSWORD=admin123

# ==================== API配置 ====================
# AI模型API密钥（根据使用的模型配置）
# 豆包模型
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_ENDPOINT=your-doubao-endpoint

# 智谱AI
ZHIPU_API_KEY=your-zhipu-api-key

# 通义千问
QWEN_API_KEY=your-qwen-api-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI (可选)
OPENAI_API_KEY=your-openai-api-key

# Claude (可选)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ==================== 前端配置 ====================
# API基础URL（Docker部署时使用相对路径）
VITE_API_BASE_URL=/api

# ==================== 数据库配置 ====================
# 数据库路径（Docker中使用默认值）
DB_PATH=./data/database.sqlite

# ==================== 文件上传配置 ====================
# 最大文件大小（MB）
MAX_FILE_SIZE=50

# ==================== 速率限制配置 ====================
# 每分钟最大请求数
RATE_LIMIT_MAX=100

# ==================== 日志配置 ====================
# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# 日志保留天数
LOG_RETENTION_DAYS=30
